# Fichiers exclus du tarball EAS Build (build APK/AAB)
# Le mobile est dans un monorepo Laravel — on n'a besoin que du dossier mobile/
# Les patterns non ancrés (sans /) matchent partout : il faut ancrer avec /

# Docker data (permissions root)
/data/

# Laravel backend (non requis pour build mobile)
/app/
/bootstrap/
/config/
/database/
/lang/
/public/
/resources/
/routes/
/storage/
/tests/
/vendor/
/scripts/
/node_modules/

# Fichiers PHP racine
/composer.json
/composer.lock
/artisan
/phpunit.xml
/docker-compose.yml
/docker-compose.dev.yml
/Dockerfile
/Dockerfile.dev
/docker-entrypoint.sh
