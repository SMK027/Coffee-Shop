# Configuration de l'URL de l'API
# Modifiez cette valeur selon votre environnement de test

# Serveur local (navigateur / Expo web)
# API_BASE_URL=http://localhost:8099

# Android Emulator (l'hôte machine est accessible via 10.0.2.2)
# API_BASE_URL=http://10.0.2.2:8099

# Appareil physique — remplacez par l'IP de votre machine sur le réseau local
# API_BASE_URL=http://192.168.1.XXX:8099

# Production
# API_BASE_URL=https://votre-domaine.com
